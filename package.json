{
  "name": "webfn-cli",
  "version": "1.0.1",
  "description": "Agent-oriented CLI for browser-backed search, fetch, crawl, and scrape workflows.",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "author": "TheAlphaOnes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NormVg/webfn.git"
  },
  "keywords": [
    "cli",
    "scraper",
    "puppeteer",
    "lightpanda",
    "cloudflare",
    "agent",
    "ai"
  ],
  "bin": {
    "webfn": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "node --import tsx src/cli.ts",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lightpanda/browser": "^1.3.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "defuddle": "^0.18.1",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.7.2",
    "linkedom": "^0.18.12",
    "puppeteer-core": "23.6.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
